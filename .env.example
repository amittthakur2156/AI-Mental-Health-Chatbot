# Flask
FLASK_ENV=development
SECRET_KEY=change-this-secret
DATABASE_URL=sqlite:///calmmind_pro.db
APP_BASE_URL=http://127.0.0.1:5000
PUBLIC_BASE_URL=https://your-ngrok-or-deployed-url.example.com

# AI
GROQ_API_KEY=GROQ_API_KEY=your_groq_api_key_here
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_TTS_MODEL=playai-tts
GROQ_TTS_VOICE=Fritz-PlayAI

# Firebase Admin: optional. Put service account JSON path here for backend token verification.
FIREBASE_SERVICE_ACCOUNT_PATH=
AUTH_MODE=demo

# Twilio: optional for phone-call demo.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Safety / privacy
ENABLE_ADMIN_DEMO=true
MAX_MESSAGE_CHARS=4000
